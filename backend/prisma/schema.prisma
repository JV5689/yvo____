generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model auditlog {
  id          String   @id
  companyId   String?
  actorId     String
  action      String
  targetId    String?
  targetModel String?
  details     Json?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())
}

model backupjob {
  id            String   @id
  companyId     String
  createdBy     Json
  backupId      String   @unique(map: "BackupJob_backupId_key")
  status        String   @default("QUEUED")
  progress      Float    @default(0)
  currentModule String?
  filters       Json?
  recordCounts  Json?
  filePath      String?
  fileSize      Float?
  expiresAt     DateTime
  error         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

model broadcastgroup {
  id          String   @id
  companyId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model broadcastgroupmember {
  id         String @id @db.VarChar(125)
  groupId    String @db.VarChar(125)
  employeeId String @db.VarChar(125)

  @@unique([groupId, employeeId], map: "BroadcastGroupMember_groupId_employeeId_key")
}

model broadcastmessage {
  id          String   @id @db.VarChar(125)
  companyId   String   @db.VarChar(125)
  senderId    String   @db.VarChar(125)
  groupId     String?  @db.VarChar(125)
  targetAll   Boolean  @default(false)
  content     String   @db.Text
  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model calendarevent {
  id               String   @id @db.VarChar(125)
  companyId        String   @db.VarChar(125)
  title            String   @db.VarChar(125)
  description      String?  @db.Text
  start            DateTime
  end              DateTime
  type             String   @default("Meeting") @db.VarChar(125)
  visibility       String   @default("public") @db.VarChar(125)
  targetCategories Json?
  attendees        Json?
  status           String   @default("Confirmed") @db.VarChar(125)
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
}

model clientlogo {
  id        String   @id @db.VarChar(125)
  name      String   @db.VarChar(125)
  logoUrl   String   @db.LongText
  createdAt DateTime @default(now())
}

model company {
  id                  String    @id @db.VarChar(125)
  name                String    @db.VarChar(125)
  businessType        String?   @db.VarChar(125)
  logo                String?   @db.LongText
  email               String?   @db.VarChar(125)
  phone               String?   @db.VarChar(125)
  website             String?   @db.VarChar(125)
  address             String?   @db.Text
  currency            String    @default("INR") @db.VarChar(125)
  planId              String    @db.VarChar(125)
  subscriptionStatus  String    @default("trial") @db.VarChar(125)
  trialEndsAt         DateTime?
  subscriptionEndsAt  DateTime?
  featureFlags        Json?
  limitOverrides      Json?
  invoiceEditPassword String?   @db.VarChar(125)
  maxDevices          Int       @default(5)
  apiKey              String?   @unique(map: "Company_apiKey_key") @db.VarChar(125)
  invoiceAttributes   Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime
}

model customer {
  id             String   @id @db.VarChar(125)
  companyId      String   @db.VarChar(125)
  name           String   @db.VarChar(125)
  email          String?  @db.VarChar(125)
  phone          String?  @db.VarChar(125)
  address        String?  @db.Text
  taxId          String?  @db.VarChar(125)
  lastModifiedAt DateTime @default(now())
  isDeleted      Boolean  @default(false)

  @@unique([companyId, phone], map: "Customer_companyId_phone_key")
}

model device {
  id         String   @id @db.VarChar(125)
  companyId  String   @db.VarChar(125)
  deviceId   String   @db.VarChar(125)
  deviceName String   @db.VarChar(125)
  lastSyncAt DateTime
  isRevoked  Boolean  @default(false)
}

model employee {
  id                 String   @id @db.VarChar(125)
  companyId          String   @db.VarChar(125)
  firstName          String   @db.VarChar(125)
  lastName           String   @db.VarChar(125)
  email              String   @unique(map: "Employee_email_key") @db.VarChar(125)
  phone              String   @unique(map: "Employee_phone_key") @db.VarChar(125)
  password           String   @db.VarChar(125)
  category           String   @default("General") @db.VarChar(125)
  avatar             String?  @db.LongText
  position           String   @db.VarChar(125)
  department         String?  @db.VarChar(125)
  salary             Float    @default(0)
  freeLeavesPerMonth Float    @default(1)
  workingDaysPerWeek Float    @default(6)
  status             String   @default("Active") @db.VarChar(125)
  dateHired          DateTime @default(now())
  isDeleted          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime
}

model expense {
  id            String   @id @db.VarChar(125)
  companyId     String   @db.VarChar(125)
  category      String   @db.VarChar(125)
  amount        Float
  date          DateTime @default(now())
  description   String?  @db.Text
  paymentMethod String?  @db.VarChar(125)
  receiptUrl    String?  @db.LongText
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

model featureflag {
  id          String   @id @db.VarChar(125)
  key         String   @unique(map: "FeatureFlag_key_key") @db.VarChar(125)
  value       Json
  description String?  @db.VarChar(125)
  scope       String   @default("global") @db.VarChar(125)
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model inventoryitem {
  id             String   @id @db.VarChar(125)
  companyId      String   @db.VarChar(125)
  sku            String   @db.VarChar(125)
  name           String   @db.VarChar(125)
  description    String?  @db.Text
  quantityOnHand Float    @default(0)
  reorderLevel   Float    @default(5)
  costPrice      Float?
  sellingPrice   Float?
  category       String?  @db.VarChar(125)
  lastModifiedAt DateTime @default(now())
  isDeleted      Boolean  @default(false)
  image          String?  @db.LongText

  @@unique([companyId, sku], map: "InventoryItem_companyId_sku_key")
}

model invoice {
  id               String   @id @db.VarChar(125)
  companyId        String   @db.VarChar(125)
  invoiceNumber    String   @db.VarChar(125)
  customerId       String   @db.VarChar(125)
  customerName     String?  @db.VarChar(125)
  clientAddress    String?  @db.Text
  gstNumber        String?  @db.VarChar(125)
  date             DateTime @default(now())
  subtotal         Float?
  taxTotal         Float?
  grandTotal       Float?
  taxRate          Float    @default(10)
  status           String   @default("DRAFT") @db.VarChar(125)
  lastModifiedAt   DateTime @default(now())
  isDeleted        Boolean  @default(false)
  templateId       String?  @db.VarChar(125)
  layout           Json?
  customAttributes Json?

  @@unique([companyId, invoiceNumber], map: "Invoice_companyId_invoiceNumber_key")
}

model invoiceitem {
  id           String  @id @db.VarChar(125)
  invoiceId    String  @db.VarChar(125)
  inventoryId  String? @db.VarChar(125)
  description  String? @db.VarChar(125)
  quantity     Float?
  price        Float?
  total        Float?
  customFields Json?
}

model invoicetemplate {
  id              String   @id @db.VarChar(125)
  companyId       String?  @db.VarChar(125)
  name            String   @db.VarChar(125)
  type            String   @default("COMPANY") @db.VarChar(125)
  themeIdentifier String   @default("classic") @db.VarChar(125)
  layout          Json?
  taxRate         Float    @default(10)
  notes           String?  @db.Text
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime
}

model invoicetemplateitem {
  id           String  @id @db.VarChar(125)
  templateId   String  @db.VarChar(125)
  inventoryId  String? @db.VarChar(125)
  description  String? @db.VarChar(125)
  quantity     Float   @default(1)
  price        Float   @default(0)
  total        Float   @default(0)
  customFields Json?
}

model leaverequest {
  id          String   @id @db.VarChar(125)
  companyId   String   @db.VarChar(125)
  employeeId  String   @db.VarChar(125)
  type        String   @db.VarChar(125)
  startDate   DateTime
  endDate     DateTime
  reason      String   @db.Text
  status      String   @default("Pending") @db.VarChar(125)
  adminRemark String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model payment {
  id         String   @id @db.VarChar(125)
  companyId  String   @db.VarChar(125)
  customerId String   @db.VarChar(125)
  amount     Float
  date       DateTime @default(now())
  method     String   @default("CASH") @db.VarChar(125)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
}

model paymentinvoiceallocation {
  id        String @id @db.VarChar(125)
  paymentId String @db.VarChar(125)
  invoiceId String @db.VarChar(125)

  @@unique([paymentId, invoiceId], map: "PaymentInvoiceAllocation_paymentId_invoiceId_key")
}

model plan {
  id            String   @id @db.VarChar(125)
  code          String   @unique(map: "Plan_code_key") @db.VarChar(125)
  name          String   @db.VarChar(125)
  priceMonthly  Float
  currency      String   @default("INR") @db.VarChar(125)
  defaultFlags  Json?
  defaultLimits Json?
  isArchived    Boolean  @default(false)
  updatedAt     DateTime
}

model salaryhistory {
  id         String   @id @db.VarChar(125)
  employeeId String   @db.VarChar(125)
  amount     Float
  changeDate DateTime @default(now())
}

model salaryrecord {
  id              String   @id @db.VarChar(125)
  companyId       String   @db.VarChar(125)
  employeeId      String   @db.VarChar(125)
  amount          Float
  baseSalary      Float?
  bonus           Float    @default(0)
  leavesTaken     Float    @default(0)
  freeLeaves      Float    @default(0)
  deductionAmount Float    @default(0)
  paymentDate     DateTime
  payPeriod       String   @db.VarChar(125)
  remarks         String?  @db.Text
  status          String   @default("Paid") @db.VarChar(125)
  slipUrl         String?  @db.LongText
  createdAt       DateTime @default(now())
  updatedAt       DateTime
}

model user {
  id           String    @id @db.VarChar(125)
  email        String    @unique(map: "User_email_key") @db.VarChar(125)
  passwordHash String?   @db.VarChar(125)
  googleId     String?   @db.VarChar(125)
  fullName     String?   @db.VarChar(125)
  avatarUrl    String?   @db.LongText
  isSuperAdmin Boolean   @default(false)
  refreshToken String?   @db.Text
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
}

model usermembership {
  id        String   @id @db.VarChar(125)
  userId    String   @db.VarChar(125)
  companyId String   @db.VarChar(125)
  role      String   @default("EMPLOYEE") @db.VarChar(125)
  joinedAt  DateTime @default(now())

  @@unique([userId, companyId], map: "UserMembership_userId_companyId_key")
}

model workreport {
  id             String   @id @db.VarChar(125)
  employeeId     String   @db.VarChar(125)
  companyId      String   @db.VarChar(125)
  date           DateTime @default(now())
  tasksCompleted String   @db.Text
  issues         String?  @db.Text
  nextDayPlan    String?  @db.Text
  status         String   @default("Submitted") @db.VarChar(125)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
}
